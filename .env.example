# ── Telegram ─────────────────────────────────────────────────────────────────
# Токен бота от @BotFather. Прод-бот: @URIST2026_1_BOT
BOT_TOKEN=
# Telegram ID администраторов через запятую (для /admin, этап 7).
ADMIN_IDS=

# ── База данных ──────────────────────────────────────────────────────────────
# В docker-compose.dev.yml DATABASE_URL переопределяется на свой postgres-сервис,
# здесь значение — fallback (напр. для запуска без Docker).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# Отдельная схема под этот бот — чужие таблицы на ПК НЕ трогаем.
DB_SCHEMA=urist_bot

# ── Redis (FSM + кеш + память диалога) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ИИ: OpenRouter (этап 2+) ─────────────────────────────────────────────────
OPENROUTER_API_KEY=
# Служебный слой (FSM/решения/уточнения) и финальный ответ+поиск.
MODEL_SERVICE=google/gemini-2.5-flash-lite
MODEL_ANSWER=google/gemini-2.5-flash

# ── Веб-поиск (этап 3+): Tavily основной, Exa/Firecrawl запасные ─────────────
# Ключи также меняются из /admin (хранятся в app_settings, применяются горячо).
TAVILY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# ── ЮKassa (этап 6) ──────────────────────────────────────────────────────────
# Для dev берём тестовые ключи из ../club_bot/.env
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Куда вернётся юзер после оплаты (домена нет → ссылка на бота).
YOOKASSA_RETURN_URL=https://t.me/URIST2026_1_BOT
# Прокси для RU-выхода на проде за границей (пусто — напрямую). socks5://… требует aiohttp_socks.
YOOKASSA_PROXY=
# Email для чека 54-ФЗ (пока не собираем реальный).
RECEIPT_EMAIL_PLACEHOLDER=receipt@example.com

# ── Экономика ────────────────────────────────────────────────────────────────
# Сколько бесплатных запросов начисляется новому пользователю на старте.
FREE_REQUESTS_ON_START=3

# ── Прочее ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
